# macOS
.DS_Store

# Editors
.vscode/
.idea/
.claude/
*.swp
*.bak

# Node / Wrangler
node_modules/
.wrangler/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bot.log

# Local env (secrets live in `wrangler secret`, never in repo)
.env
.env.local
.dev.vars

# Circuit build outputs — regenerated by each circuit's build.sh. Source
# files (*.circom, build.sh, prove-sample.mjs, package.json) are tracked;
# compiled r1cs / wasm / sym / zkey / verifying-key / sample proof are not.
# The amm/build subdir slipped through this rule once and bloated a push
# past libcurl's http.postBuffer (HTTP 400); the */build pattern catches
# every per-circuit build dir going forward.
dapp/circuits/artifacts/
dapp/circuits/build/
dapp/circuits/*/build/
# Verified Phase 1 ptau (~18 MB) — regenerable via build.sh's hash-checked
# curl. Keeping it out of git history.
dapp/circuits/verified-ptau/
# Ceremony finalize bundle (~32 MB) — staged by finalize.sh for IPFS
# pinning. Auditable via the published IPFS CID; no need in git history.
# Exception: the 3.6 KB verification_key.json is tracked so bridge-guards CI
# can pin the on-chain Groth16Verifier VK against it (the large ptau/r1cs/zkey
# are fetched by CID in the workflow and sha-pinned by the test).
dapp/circuits/ceremony-bundle/*
!dapp/circuits/ceremony-bundle/verification_key.json
# Dev ceremony scratch — local pot*.ptau / *.zkey / *.wtns + proof/public
# blobs generated by build-dev-zkey.sh. pot18_final.ptau alone is 192 MB
# (above GitHub's 100 MB per-file ceiling). Source scripts (.sh, demo
# .mjs, input .json shape) ARE tracked so the directory's purpose stays
# documented; only the large binary outputs are excluded.
dapp/circuits/amm/dev-zkey/*.ptau
dapp/circuits/amm/dev-zkey/*.zkey
dapp/circuits/amm/dev-zkey/*.wtns
dapp/circuits/amm/dev-zkey/proof*.json
dapp/circuits/amm/dev-zkey/public*.json
# Production AMM ceremony kickoff artifacts — pot18 (288 MB, Hermez source,
# BLAKE2b-pinned, regenerable via finalize-amm.sh's hash-checked fetch) and
# the three genesis zkeys produced by `snarkjs groth16 setup` against each
# circuit's r1cs (swap_batch zkey is 91 MB, above GitHub's 100 MB ceiling
# even compressed). Once /ceremony/init has accepted them, the worker hosts
# the canonical chain on IPFS — local copies are operational scratch.
dapp/circuits/pot18_final.ptau
dapp/circuits/ceremony-genesis-amm/
dapp/circuits/build-amm/
dapp/circuits/ceremony-bundle-amm/
# Test-runner scratch — *.test.mjs harnesses write per-circuit
# {input,proof,public}.json under `_rt_*` / `_wire_*` prefixes;
# regenerated on every run.
dapp/circuits/amm/dev-zkey/_rt_*.json
dapp/circuits/amm/dev-zkey/_wire_*.json

# Signet e2e state (test/ephemeral wallet privs — regenerable, never commit).
.local/

# local testnet deployer key (never commit)
contracts/.deployer.env

.env.mainnet

# one-off SP1 proof outputs (proof_bytes/public_values hex)
contracts/sp1/*.hex
